# Anthropic Claude API Client Library
#
# Provides chat completion using Anthropic's Claude API
#
# Usage:
#   load("lib/anthropic.fmpl")
#   let response = claude.chat("What is 2+2?")
#   print(response)
#
# Requires ANTHROPIC_API_KEY environment variable
#
# Reference: https://docs.anthropic.com/claude/reference/messages_post

# Anthropic API endpoint
anthropic.endpoint = "https://api.anthropic.com/v1/messages"

# Default model (Claude Sonnet 4.5)
anthropic.model = "claude-sonnet-4-20250514"

# Anthropic version header
anthropic.version = "2023-06-01"

# Get API key from environment (placeholder - needs env builtin)
anthropic.get_api_key = \
  # TODO: Implement env.get() builtin
  "sk-ant-api03-YOUR-API-KEY-HERE"

# Send a chat completion request to Claude
# Returns the response text as a string
anthropic.chat = \prompt
  let api_key = anthropic.get_api_key()

  let body = json::stringify(%{
    model: anthropic.model,
    max_tokens: 1024,
    messages: [%{
      role: "user",
      content: prompt
    }]
  })

  # Note: curl.post doesn't support custom headers yet
  # We need to add header support to curl builtin
  # For now, this is a placeholder showing the intended API

  # let response = curl.post_with_headers(
  #   anthropic.endpoint,
  #   body,
  #   %{
  #     "x-api-key": api_key,
  #     "anthropic-version": anthropic.version,
  #     "content-type": "application/json"
  #   }
  # )

  "Error: curl.post_with_headers not implemented yet. See lib/anthropic.fmpl"

# Parse Claude's JSON response to extract the text
# Claude returns: {"content": [{"type": "text", "text": "..."}], ...}
anthropic.parse_response = \json_text
  let parsed = json::parse(json_text)

  @ parsed {
    # Claude's response format
    %{content: [%{type: "text", text: response_text}]} => response_text
    %{content: list} =>
      # Extract text from first content block
      @ list {
        [%{type: "text", text: response_text}, ...] => response_text
        _ => "Unexpected content format"
      }
    %{error: %{message: msg}} => "Error: " + msg
    _ => "Unexpected response: " + json_text
  }

# Multi-turn conversation with message history
anthropic.chat_history = \messages
  let api_key = anthropic.get_api_key()

  let body = json::stringify(%{
    model: anthropic.model,
    max_tokens: 1024,
    messages: messages
  })

  # TODO: Implement with header support
  "Error: curl.post_with_headers not implemented yet. See lib/anthropic.fmpl"

# Stream completion (Claude supports SSE streaming)
anthropic.chat_stream = \prompt
  # TODO: Implement with header + stream parsing
  "Error: Streaming not implemented yet"
