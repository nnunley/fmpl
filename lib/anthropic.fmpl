# Anthropic Claude API Client Library
#
# Provides chat completion using Anthropic's Claude API
#
# Usage:
#   io.load("lib/anthropic.fmpl")
#   let response = anthropic.chat("What is 2+2?")
#   print(response)
#
# Requires ANTHROPIC_API_KEY environment variable
#
# Reference: https://docs.anthropic.com/claude/reference/messages_post

# Anthropic API endpoint
anthropic.endpoint = "https://api.anthropic.com/v1/messages"

# Default model (Claude Sonnet 4.5)
anthropic.model = "claude-sonnet-4-20250514"

# Anthropic version header
anthropic.version = "2023-06-01"

# Get API key from environment
anthropic.get_api_key = \
  env.get("ANTHROPIC_API_KEY")

# Send a chat completion request to Claude
# Returns the response text as a string
anthropic.chat = \prompt
  let api_key = anthropic.get_api_key()

  if api_key == null then
    "Error: ANTHROPIC_API_KEY environment variable not set"
  else
    let body = json::stringify(%{
      model: anthropic.model,
      max_tokens: 1024,
      messages: [%{
        role: "user",
        content: prompt
      }]
    })

    let response = ::__builtin_curl.post(
      anthropic.endpoint,
      body,
      %{headers: %{
        "x-api-key": api_key,
        "anthropic-version": anthropic.version,
        "content-type": "application/json",
        "accept": "application/json"
      }}
    )

    # Wait for async response and parse
    @ response.source {
      %{ok: json_text} => anthropic.parse_response(json_text)
      %{error: e} => "Error: " + json::stringify(e)
    }

# Parse Claude's JSON response to extract the text
# Claude returns: {"content": [{"type": "text", "text": "..."}], ...}
anthropic.parse_response = \json_text
  let parsed = json::parse(json_text)

  @ parsed {
    # Claude's response format
    %{content: [%{type: "text", text: response_text}]} => response_text
    %{content: list} =>
      # Extract text from first content block
      # (using pattern matching on list index when available)
      "TODO: extract text from content list"
    %{error: %{message: msg}} => "Error: " + msg
    _ => "Unexpected response: " + json_text
  }

# Multi-turn conversation with message history
# Alias for consistency with ollama.chat_with_history()
anthropic.chat_with_history = anthropic.chat_history
anthropic.chat_history = \messages
  let api_key = anthropic.get_api_key()

  if api_key == null then
    "Error: ANTHROPIC_API_KEY environment variable not set"
  else
    let body = json::stringify(%{
      model: anthropic.model,
      max_tokens: 1024,
      messages: messages
    })

    let response = ::__builtin_curl.post(
      anthropic.endpoint,
      body,
      %{headers: %{
        "x-api-key": api_key,
        "anthropic-version": anthropic.version,
        "content-type": "application/json"
      }}
    )

    @ response.source {
      %{ok: json_text} => anthropic.parse_response(json_text)
      %{error: e} => "Error: " + json::stringify(e)
    }

# Stream completion with SSE parsing
# Returns concatenated response text from all SSE chunks
anthropic.chat_stream = \prompt
  let api_key = anthropic.get_api_key()

  if api_key == null then
    "Error: ANTHROPIC_API_KEY environment variable not set"
  else
    let body = json::stringify(%{
      model: anthropic.model,
      max_tokens: 1024,
      stream: true,
      messages: [%{
        role: "user",
        content: prompt
      }]
    })

    let response = ::__builtin_curl.post(
      anthropic.endpoint,
      body,
      %{headers: %{
        "x-api-key": api_key,
        "anthropic-version": anthropic.version,
        "content-type": "application/json"
      }}
    )

    # Get the SSE response text
    let response_text = response.source |> stream::collect

    # Parse SSE format and extract tokens
    @ response_text {
      %{error: e} => "Error: " + json::stringify(e)
      text => {
        let events = sse.parse(text)

        # Extract tokens from Anthropic events
        # Anthropic format: {"type": "content_block_delta", "delta": {"type": "text_delta", "text": "token"}}
        anthropic.extract_deltas(events)
      }
    }

# Extract and concatenate all delta.text fields from Anthropic SSE events
anthropic.extract_deltas = \events
  @ events {
    [] => ""
    [head, ...tail] => {
      let token = @ head {
        %{type: "content_block_delta", delta: %{type: "text_delta", text: text}} => text
        %{type: "content_block_delta", delta: %{text: text}} => text
        _ => ""
      }
      token + anthropic.extract_deltas(tail)
    }
  }

