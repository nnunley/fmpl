-- AST→IR Transformation Grammar
--
-- This tree grammar transforms FMPL AST tagged values into IR tagged values
-- that can be compiled by ir::compile.
--
-- Usage:
--   let ast = ast::parse("1 + 2")
--   let ir = ast @ ast_to_ir.ir
--   code::eval(ir::compile(ir))
--
-- Note: This grammar uses base::tree for value/tree matching.
-- Child bindings are recursively transformed when the grammar descends.

grammar ast_to_ir <: base::tree {
    -- ============================================================
    -- LITERALS
    -- ============================================================

    -- Integer literals: :Int(42) => :LoadInt(42)
    ir = :Int(n) => :LoadInt(n)

       -- Boolean literals: :Bool(true) => :LoadBool(true)
       | :Bool(b) => :LoadBool(b)

       -- Null literal: :Null() => :LoadNull()
       | :Null() => :LoadNull()

       -- String literals: :String("hello") => :LoadString("hello")
       | :String(s) => :LoadString(s)

       -- Float literals: :Float(3.14) => :LoadFloat(3.14)
       | :Float(f) => :LoadFloat(f)

    -- ============================================================
    -- VARIABLES
    -- ============================================================

       -- Simple identifier: :Var(:name) => :Var(:name)
       | :Var(name) => :Var(name)

    -- ============================================================
    -- BINARY OPERATIONS
    -- ============================================================

       -- Arithmetic
       | :Binary(:+, l, r) => :Add(l @ ir, r @ ir)
       | :Binary(:-, l, r) => :Sub(l @ ir, r @ ir)
       | :Binary(:*, l, r) => :Mul(l @ ir, r @ ir)
       | :Binary(:/, l, r) => :Div(l @ ir, r @ ir)
       | :Binary(:%, l, r) => :Mod(l @ ir, r @ ir)

       -- Comparisons
       | :Binary(:==, l, r) => :Eq(l @ ir, r @ ir)
       | :Binary(:!=, l, r) => :NotEq(l @ ir, r @ ir)
       | :Binary(:<, l, r) => :Lt(l @ ir, r @ ir)
       | :Binary(:>, l, r) => :Gt(l @ ir, r @ ir)
       | :Binary(:<=, l, r) => :LtEq(l @ ir, r @ ir)
       | :Binary(:>=, l, r) => :GtEq(l @ ir, r @ ir)

    -- ============================================================
    -- UNARY OPERATIONS
    -- ============================================================

       | :Unary(:-, e) => :Neg(e @ ir)
       | :Unary(:!, e) => :Not(e @ ir)

    -- ============================================================
    -- CONTROL FLOW
    -- ============================================================

       -- If/then/else: :If(cond, then, else) => :If(cond_ir, then_ir, else_ir)
       | :If(c, t, e) => :If(c @ ir, t @ ir, e @ ir)

    -- ============================================================
    -- LET BINDINGS
    -- ============================================================

       -- Let with single simple binding:
       -- :Let([:Binding(:name, :Int(42))], :Var(:name))
       -- => :Let(:name, :LoadInt(42), :Var(:name))
       | :Let([[:Binding(name, val)]], body) => :Let(name, val @ ir, body @ ir)

       -- Multiple bindings become nested Lets
       | :Let([[:Binding(n1, v1), :Binding(n2, v2)]], body)
         => :Let(n1, v1 @ ir, :Let(n2, v2 @ ir, body @ ir))

    -- ============================================================
    -- LISTS (Phase 2)
    -- ============================================================

       -- List literal: :List([e1, e2, ...]) => :MakeList([ir1, ir2, ...])
       | :List(elements) => :MakeList(list::map(\e e @ ir, elements))

    -- ============================================================
    -- MAPS (Phase 2)
    -- ============================================================

       -- Map literal: :Map([[k1, v1], [k2, v2], ...]) => :MakeMap([[k1_ir, v1_ir], ...])
       | :Map(pairs) => :MakeMap(list::map(\pair [pair[0] @ ir, pair[1] @ ir], pairs))

    -- ============================================================
    -- INDEX (Phase 2)
    -- ============================================================

       -- Index expression: :Index(collection, key) => :Index(collection_ir, key_ir)
       | :Index(coll, key) => :Index(coll @ ir, key @ ir)

    -- ============================================================
    -- CALLS (Phase 3)
    -- ============================================================

       -- Function call: :Call(func, [args...]) => :Call(func_ir, [arg_irs...])
       | :Call(func, args) => :Call(func @ ir, list::map(\a a @ ir, args))

       -- Method call: :MethodCall(recv, :name, [args...])
       | :MethodCall(recv, name, args) => :MethodCall(recv @ ir, name, list::map(\a a @ ir, args))

    -- ============================================================
    -- CONTROL FLOW (Phase 4)
    -- ============================================================

       -- Return: :Return(expr) => :Return(ir)
       | :Return(e) => :Return(e @ ir)

       -- Note: While loops compile to jump instructions, not a single IR node.
       -- Full While support would require emitting multiple instructions.
}
