-- FMPL Parser Grammar - Produces AST Tagged Values
--
-- This grammar parses FMPL source code and produces AST tagged values
-- compatible with ast::parse output, enabling the self-interpreter pipeline:
--
--   source @ fmpl_parser.code => AST tagged value
--   ast @ ast_to_ir.ir => IR tagged value
--   ir::compile(ir) => compiled bytecode
--   code::eval(bytecode) => result
--
-- Phase 1: Core expressions (literals, arithmetic, comparisons, if, let)

grammar fmpl_parser <: base::parser {
    -- ============================================================
    -- WHITESPACE AND COMMENTS
    -- ============================================================

    ws = [ \t\n\r]*
    comment = "--" [^\n]* "\n"?
    _ = (ws | comment)*

    -- ============================================================
    -- LITERALS
    -- ============================================================

    -- Integer literal: produces :Int(n)
    int = ds:digit+ _ => :Int(string::to_int(list::join(ds)))

    -- Boolean literal: produces :Bool(true/false)
    bool = "true" _ => :Bool(true)
         | "false" _ => :Bool(false)

    -- Null literal: produces :Null()
    null_lit = "null" _ => :Null()

    -- String literal: produces :String(s)
    string_lit = "\"" cs:string_char* "\"" _ => :String(list::join(cs))
    string_char = "\\" c:escape_char => unescape(c)
               | [^"\\]:c => c
    escape_char = [nrt"\\]

    -- ============================================================
    -- IDENTIFIERS
    -- ============================================================

    -- Keywords (not identifiers)
    keyword = ("let" | "if" | "then" | "else" | "true" | "false" | "null") ~ident_char

    -- Identifier: produces the identifier string
    ident = ~keyword first:(letter | "_") rest:ident_char* _ => list::join([first] ++ rest)
    ident_char = letter | digit | "_"

    -- ============================================================
    -- EXPRESSIONS (precedence climbing)
    -- ============================================================

    -- Entry point: full expression
    expr = if_expr | let_expr | or_expr

    -- If/then/else: produces :If(cond, then, else)
    if_expr = "if" _ cond:expr "then" _ then_branch:expr "else" _ else_branch:expr
            => :If(cond, then_branch, else_branch)

    -- Let binding: produces :Let([[:Binding(:name, value)]], body)
    -- Note: Single binding syntax for Phase 1
    let_expr = "let" _ "(" _ name:ident "=" _ value:expr ")" _ body:expr
             => :Let([[:Binding(:name, value)]], body)

    -- Logical OR (lowest precedence)
    or_expr = first:and_expr rest:("||" _ and_expr)* => fold_or(first, rest)

    -- Logical AND
    and_expr = first:cmp_expr rest:("&&" _ cmp_expr)* => fold_and(first, rest)

    -- Comparison operators
    cmp_expr = lhs:add_expr op:cmp_op rhs:add_expr => :Binary(op, lhs, rhs)
             | add_expr
    cmp_op = "==" _ => :==
           | "!=" _ => :!=
           | "<=" _ => :<=
           | ">=" _ => :>=
           | "<" _ => :<
           | ">" _ => :>

    -- Addition and subtraction
    add_expr = first:mult_expr rest:(add_op mult_expr)* => fold_binary(first, rest)
    add_op = "+" _ => :+
           | "-" _ => :-

    -- Multiplication, division, modulo
    mult_expr = first:unary_expr rest:(mult_op unary_expr)* => fold_binary(first, rest)
    mult_op = "*" _ => :*
            | "/" _ => :/
            | "%" _ => :%

    -- Unary operators (highest precedence)
    unary_expr = "-" _ e:unary_expr => :Unary(:-, e)
               | "!" _ e:unary_expr => :Unary(:!, e)
               | primary

    -- Primary expressions
    primary = "(" _ e:expr ")" _ => e
            | int
            | bool
            | null_lit
            | string_lit
            | name:ident => :Var(:name)

    -- ============================================================
    -- TOP-LEVEL ENTRY POINT
    -- ============================================================

    -- Single expression entry point
    code = _ e:expr _ ~. => e
}

-- Helper functions for building AST
-- These would be built-in or defined elsewhere

-- fold_binary takes first element and rest list, folds left-to-right
-- fold_binary(1, [[+, 2], [+, 3]]) => :Binary(:+, :Binary(:+, 1, 2), 3)

-- fold_or/fold_and are similar for logical operators
