# Build artifacts (root and per-crate target/ dirs)
target/

# Node (stray npm artifacts; this is a Rust project)
node_modules/

# macOS
.DS_Store

# IDE
.idea/
.vscode/
*.swp
*.swo

# Private journal (personal notes)
.private-journal/
.opencode/
data/

# Ralph loop logs and transient state
.ralph-logs/
.claude/.ralph-state.json
ralph.yml
ralph.oc.yml

# Python bytecode
__pycache__/

# Git worktrees
.worktrees/
.worklists/
.jj/
.agents/

# Agentic-stack claude-code adapter plugin (generated locally pending upstream)
.agent/transfer/claude-code-plugin/

# fastembed model cache (large binary blobs, regenerated on demand)
.fastembed_cache/

# Test artifacts (generated by running tests)
test_*
# Keep test source files
!tests/

# Override global ignore for iterative-development artifacts
!docs/superpowers/
docs/superpowers/iterations/scratch/
docs/superpowers/specs/.clearance-rendered-preview-*/
