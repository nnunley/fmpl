# Build artifacts
/target/
# Stray rlib emissions to the repo root (e.g. a one-off
# `rustc --crate-name X` outside cargo emits to CWD by default).
# ITER-0005a.5 T1 had one such artifact appear; ITER-0005b closing
# PAR R-L-C-1 made the policy explicit.
*.rlib

# macOS
.DS_Store

# IDE
.idea/
.vscode/
*.swp
*.swo

# Private journal (personal notes)
.private-journal/
.opencode/
data/

# Ralph loop logs and transient state
.ralph-logs/
.claude/.ralph-state.json
ralph.yml
ralph.oc.yml

# Python bytecode
__pycache__/

# Git worktrees
.worktrees/
.worklists/
.jj/
.agents/

# Agentic-stack claude-code adapter plugin (generated locally pending upstream)
.agent/transfer/claude-code-plugin/

# fastembed model cache (large binary blobs, regenerated on demand)
.fastembed_cache/

# Test artifacts (generated by running tests)
test_*
# Keep test source files
!tests/

# Override global ignore for iterative-development artifacts
!docs/superpowers/
docs/superpowers/iterations/scratch/
docs/superpowers/specs/.clearance-rendered-preview-*/

# Override global ignore for OpenSpec spec-driven-development artifacts
!openspec/
!openspec/**
