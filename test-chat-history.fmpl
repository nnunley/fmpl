# Test script for chat_with_history functionality
#
# This tests the new chat_with_history() function that enables
# multi-turn conversations with context

# Load Ollama library
io.load("lib/ollama.fmpl")

# Test 1: Single-turn with history (should work like chat())
let messages1 = [%{role: "user", content: "What is 2+2?"}]
let response1 = ollama.chat_with_history(messages1)
print("Test 1 - Single turn:")
print(response1)
print("")

# Test 2: Multi-turn conversation
let messages2 = [
  %{role: "user", content: "My name is Alice"},
  %{role: "assistant", content: "Hello Alice! Nice to meet you."},
  %{role: "user", content: "What's my name?"}
]
let response2 = ollama.chat_with_history(messages2)
print("Test 2 - Multi-turn (should remember name):")
print(response2)
print("")

# Test 3: Empty history (edge case)
let messages3 = []
let response3 = ollama.chat_with_history(messages3)
print("Test 3 - Empty history:")
print(response3)
print("")

print("All tests completed!")
